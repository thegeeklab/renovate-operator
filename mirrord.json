{
  "target": {
    "path": "deployment/renovate-operator-controller-manager",
    "namespace": "renovate-system"
  },
  "agent": {
    "namespace": "renovate-system"
  },
  "feature": {
    "network": {
      "incoming": {
        "mode": "steal",
        "ignore_ports": [8081]
      },
      "outgoing": {
        "ignore_localhost": true
      }
    },
    "fs": {
      "mode": "local"
    }
  }
}
